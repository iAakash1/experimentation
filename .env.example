# PlantDx environment overrides (copy to .env; .env is gitignored).
# All settings also live in configs/; environment variables take precedence
# when PLANTDX_* is set. Optional — the framework runs from configs/ alone.

# Root for generated pipeline artifacts (see configs/paths.yaml: artifact_root).
# PLANTDX_ARTIFACT_ROOT=artifacts

# Global RNG seed (overrides configs/generation.yaml: global_seed).
# PLANTDX_GLOBAL_SEED=20260711

# Logging level: DEBUG | INFO | WARNING | ERROR
# PLANTDX_LOG_LEVEL=INFO

# Path to the (frozen) Disease Knowledge Base.
# PLANTDX_DKB_PATH=knowledge_base/dkb.json
